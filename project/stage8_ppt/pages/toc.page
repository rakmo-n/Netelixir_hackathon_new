pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  - elementId: top-bar
    elementType: shape
    bounds: [0, 0, 1280, 6]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"
  - elementId: toc-title
    elementType: text
    bounds: [60, 20, 1160, 36]
    content:
      style: "$actionTitle"
      align: [left, middle]
      wrap: false
      text: |
        <p>Table of Contents</p>
  - elementId: divider
    elementType: shape
    bounds: [60, 62, 1160, 1]
    shapeName: rect
    fill:
      type: solid
      color: "$border"
  - elementId: toc-item1
    elementType: text
    bounds: [60, 90, 1160, 80]
    content:
      fontSize: 20
      color: "$text"
      fontFamily: "Liter"
      lineHeight: 1.4
      align: [left, middle]
      text: |
        <p><span style="font-size:28px; color:$primary; font-family:Oranienbaum;">01</span>   <strong>Executive Summary</strong> — Key metrics, critical insights, and performance overview</p>
