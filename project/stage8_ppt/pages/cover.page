pageType: cover
background:
  type: solid
  color: "$background"
elements:
  - elementId: top-bar
    elementType: shape
    bounds: [0, 0, 1280, 6]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"
  - elementId: cover-title
    elementType: text
    bounds: [60, 200, 1160, 80]
    content:
      style: "$coverTitle"
      align: [center, middle]
      wrap: false
      text: |
        <p>AIgnition Executive Report</p>
  - elementId: accent-line
    elementType: shape
    bounds: [440, 295, 400, 2]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
  - elementId: cover-subtitle
    elementType: text
    bounds: [60, 315, 1160, 60]
    content:
      style: "$coverSubtitle"
      align: [center, middle]
      wrap: false
      text: |
        <p>Probabilistic Demand Forecasting, Budget Simulation &amp; AI Explanation</p>
  - elementId: cover-meta
    elementType: text
    bounds: [60, 400, 1160, 30]
    content:
      fontSize: 16
      color: "$secondary"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p>AIgnition Pipeline  |  Stages 1–9  |  Data Period: Jan 2024 – Jun 2026</p>
  - elementId: cover-date
    elementType: text
    bounds: [60, 440, 1160, 24]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p>Generated: June 2026  |  25,562 Records  |  14 Grains Analyzed</p>
